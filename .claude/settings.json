{
  "permissions": {
    "allow": [
      "Edit",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run dev:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(.env*)",
      "Bash(git push --force:*)"
    ]
  }
}
